<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WingetUSoft.CleanupWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WingetUSoft"
    Title="WingetUSoft - Limpieza de residuos">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="32" Background="Transparent">
            <TextBlock Text="Limpieza de residuos"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"
                       Style="{StaticResource CaptionTextBlockStyle}" />
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Row="1" Padding="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header Card -->
            <Border Grid.Row="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20,14"
                    Margin="0,0,0,12">
                <StackPanel Spacing="4">
                    <TextBlock Text="Limpieza de residuos tras la desinstalación"
                               Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock x:Name="txtSubtitulo"
                               Text="Buscando residuos..."
                               Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="⚠ Verifica cuidadosamente cada elemento antes de eliminar. Esta acción no se puede deshacer."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource SystemFillColorCautionBrush}"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <!-- Actions Bar -->
            <Border Grid.Row="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16,12"
                    Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="btnEscanear"
                            Content="Volver a escanear"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="BtnEscanear_Click"
                            MinWidth="160" Height="36" />
                    <Button x:Name="btnEliminar"
                            Content="Eliminar seleccionados"
                            Click="BtnEliminar_Click"
                            IsEnabled="False"
                            MinWidth="190" Height="36">
                        <Button.Resources>
                            <ResourceDictionary>
                                <ResourceDictionary.ThemeDictionaries>
                                    <ResourceDictionary x:Key="Light">
                                        <SolidColorBrush x:Key="ButtonBackground" Color="#FFBA4636" />
                                        <SolidColorBrush x:Key="ButtonForeground" Color="White" />
                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FFD05040" />
                                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                                    </ResourceDictionary>
                                    <ResourceDictionary x:Key="Dark">
                                        <SolidColorBrush x:Key="ButtonBackground" Color="#FFD55C4C" />
                                        <SolidColorBrush x:Key="ButtonForeground" Color="White" />
                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FFE06858" />
                                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                                    </ResourceDictionary>
                                </ResourceDictionary.ThemeDictionaries>
                            </ResourceDictionary>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="btnSelAll"
                            Content="Seleccionar todo"
                            Click="BtnSelAll_Click"
                            Height="36" />
                    <Button x:Name="btnDeselAll"
                            Content="Deseleccionar todo"
                            Click="BtnDeselAll_Click"
                            Height="36" />
                    <Button x:Name="btnCancelar"
                            Content="Cancelar"
                            Click="BtnCancelar_Click"
                            IsEnabled="False"
                            Height="36" />
                </StackPanel>
            </Border>

            <!-- Main split: List + Log -->
            <Grid Grid.Row="2" Margin="0,0,0,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" MinHeight="100" />
                </Grid.RowDefinitions>

                <!-- Residuals List Card -->
                <Border Grid.Row="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Residuos encontrados"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   Margin="4,0,0,8" />

                        <!-- Column Headers -->
                        <Grid Grid.Row="1" Height="36"
                              Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                              CornerRadius="4,4,0,0"
                              Padding="8,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="160" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="Ruta" VerticalAlignment="Center" FontWeight="SemiBold" Margin="4,0,0,0" />
                            <TextBlock Grid.Column="2" Text="Tipo" VerticalAlignment="Center" FontWeight="SemiBold" Margin="8,0,0,0" />
                            <TextBlock Grid.Column="3" Text="Tamaño" VerticalAlignment="Center" FontWeight="SemiBold" Margin="8,0,0,0" />
                            <TextBlock Grid.Column="4" Text="Programa" VerticalAlignment="Center" FontWeight="SemiBold" Margin="8,0,0,0" />
                        </Grid>

                        <ListView x:Name="lvItems"
                                  Grid.Row="2"
                                  SelectionMode="None">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="38" Padding="8,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="160" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  Checked="OnItemCheckChanged"
                                                  Unchecked="OnItemCheckChanged"
                                                  VerticalAlignment="Center"
                                                  Padding="0" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Path}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="4,0,0,0"
                                                   ToolTipService.ToolTip="{Binding Path}" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding TypeLabel}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="8,0,0,0" />
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding DisplaySize}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="8,0,0,0"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Grid.Column="4"
                                                   Text="{Binding PackageName}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="8,0,0,0"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <!-- Splitter -->
                <Border Grid.Row="1" Height="6" Background="Transparent" />

                <!-- Log Card -->
                <Border Grid.Row="2"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Text="Actividad"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   Margin="4,0,0,8" />
                        <ScrollViewer Grid.Row="1"
                                      x:Name="scrollLog"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                            <RichTextBlock x:Name="rtbLog"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           IsTextSelectionEnabled="True"
                                           TextWrapping="NoWrap" />
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- Status Bar -->
            <Border Grid.Row="3"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="txtEstado"
                               Grid.Column="0"
                               Text="Listo."
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />
                    <ProgressRing x:Name="progressRing"
                                  Grid.Column="1"
                                  IsActive="False"
                                  Width="20" Height="20"
                                  Margin="12,0,0,0" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
