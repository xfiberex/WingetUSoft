<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WingetUSoft.HistoryWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WingetUSoft"
    Title="Historial de actualizaciones">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header Card -->
        <Border Grid.Row="0"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="20,16"
                Margin="0,0,0,12">
            <StackPanel Spacing="4">
                <TextBlock Text="Historial reciente"
                           Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock x:Name="txtSummary"
                           Text="Consulta el resultado de las ultimas actualizaciones ejecutadas desde la aplicacion."
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Border>

        <!-- History List -->
        <Border Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12"
                Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Column Headers -->
                <Grid Grid.Row="0" Height="36"
                      Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                      CornerRadius="4,4,0,0"
                      Padding="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="155" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="210" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="120" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Fecha" VerticalAlignment="Center" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="Nombre" VerticalAlignment="Center" FontWeight="SemiBold" Margin="8,0,0,0" />
                    <TextBlock Grid.Column="2" Text="Id" VerticalAlignment="Center" FontWeight="SemiBold" Margin="8,0,0,0" />
                    <TextBlock Grid.Column="3" Text="Version origen" VerticalAlignment="Center" FontWeight="SemiBold" Margin="8,0,0,0" />
                    <TextBlock Grid.Column="4" Text="Version destino" VerticalAlignment="Center" FontWeight="SemiBold" Margin="8,0,0,0" />
                    <TextBlock Grid.Column="5" Text="Estado" VerticalAlignment="Center" FontWeight="SemiBold" Margin="8,0,0,0" />
                </Grid>

                <ListView x:Name="lvHistory"
                          Grid.Row="1"
                          SelectionMode="Single"
                          IsItemClickEnabled="False">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:HistoryEntryViewModel">
                            <Grid Height="34" Padding="12,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="155" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="210" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Bind DateDisplay}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="1" Text="{x:Bind PackageName}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" Margin="8,0,0,0" />
                                <TextBlock Grid.Column="2" Text="{x:Bind PackageId}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" Margin="8,0,0,0" />
                                <TextBlock Grid.Column="3" Text="{x:Bind FromVersion}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" Margin="8,0,0,0" />
                                <TextBlock Grid.Column="4" Text="{x:Bind ToVersion}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" Margin="8,0,0,0" />
                                <TextBlock Grid.Column="5" Text="{x:Bind StatusDisplay}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" Margin="8,0,0,0" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button x:Name="btnCerrar" Content="Cerrar" MinWidth="120" Height="36"
                    Click="BtnCerrar_Click" />
        </StackPanel>
    </Grid>
</Window>
