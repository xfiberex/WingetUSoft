<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WingetUSoft.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Configuración">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="32" Background="Transparent">
            <TextBlock x:Name="txtTitleBar" Text="Configuración"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"
                       Style="{StaticResource CaptionTextBlockStyle}" />
        </Grid>

        <!-- Header Card -->
        <Border Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="20,16"
                Margin="20,4,20,12">
            <StackPanel Spacing="4">
                <TextBlock x:Name="txtHeaderTitle" Text="Configuración"
                           Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock x:Name="txtHeaderSubtitle" Text="Ajusta las opciones generales de la aplicación."
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Border>

        <!-- Settings Content -->
        <ScrollViewer Grid.Row="2" Margin="20,0,20,16">
            <StackPanel Spacing="16">

                <!-- Apariencia: tema e idioma. Vivían en el menú "Opciones" de la ventana principal
                     hasta v1.5.0, partiendo las preferencias entre dos sitios (Tier C #5). -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16,12">
                    <StackPanel Spacing="10">
                        <TextBlock x:Name="txtAppearanceTitle" Text="Apariencia"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <StackPanel Spacing="6">
                            <TextBlock x:Name="txtThemeLabel" Text="Tema"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <RadioButtons x:Name="rbTema" MaxColumns="3">
                                <RadioButton x:Name="rbTemaSistema" Content="Sistema (automático)" />
                                <RadioButton x:Name="rbTemaClaro" Content="Claro" />
                                <RadioButton x:Name="rbTemaOscuro" Content="Oscuro" />
                            </RadioButtons>
                        </StackPanel>
                        <ComboBox x:Name="cmbIdioma" Width="280" Header="Idioma">
                            <ComboBoxItem x:Name="itemLangEs" Content="Español" />
                            <ComboBoxItem x:Name="itemLangEn" Content="Inglés" />
                            <ComboBoxItem x:Name="itemLangPt" Content="Portugués" />
                            <ComboBoxItem x:Name="itemLangFr" Content="Francés" />
                            <ComboBoxItem x:Name="itemLangIt" Content="Italiano" />
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Actualizaciones: cómo se ejecutan (modo, permisos) y cada cuánto se consultan -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16,12">
                    <StackPanel Spacing="10">
                        <TextBlock x:Name="txtUpdatesTitle" Text="Actualizaciones"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <StackPanel Spacing="6">
                            <TextBlock x:Name="txtUpdateModeLabel" Text="Modo de actualización"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <RadioButtons x:Name="rbModo" MaxColumns="2">
                                <RadioButton x:Name="rbModoSilencioso" Content="Silenciosa" />
                                <RadioButton x:Name="rbModoInteractivo" Content="Interactiva" />
                            </RadioButtons>
                        </StackPanel>
                        <CheckBox x:Name="chkAdministrador" Content="Ejecutar actualizaciones como administrador" />
                        <ComboBox x:Name="cmbIntervalo" Width="280"
                                  Header="Intervalo de consulta automática">
                            <ComboBoxItem x:Name="itemIntervalOff" Content="Desactivada" />
                            <ComboBoxItem x:Name="itemInterval30" Content="Cada 30 minutos" />
                            <ComboBoxItem x:Name="itemInterval60" Content="Cada 60 minutos" />
                            <ComboBoxItem x:Name="itemInterval120" Content="Cada 120 minutos" />
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Registro de actividad -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16,12">
                    <StackPanel Spacing="10">
                        <TextBlock x:Name="txtLogTitle" Text="Registro de actividad"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <CheckBox x:Name="chkLogArchivo" Content="Guardar registro de actividad en archivo" />
                        <StackPanel Spacing="4">
                            <TextBlock x:Name="txtLogDirLabel" Text="Directorio de registros:"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBox x:Name="txtLogPath" IsReadOnly="True" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Notifications & Tray -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16,12">
                    <StackPanel Spacing="10">
                        <TextBlock x:Name="txtNotifTrayTitle" Text="Notificaciones y bandeja"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="txtShowNotifLabel" Text="Mostrar notificaciones al completar actualizaciones"
                                       VerticalAlignment="Center"/>
                            <ToggleSwitch x:Name="tsShowNotifications" Grid.Column="1" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="txtMinimizeTrayLabel" Text="Minimizar a la bandeja del sistema al cerrar"
                                       VerticalAlignment="Center"/>
                            <ToggleSwitch x:Name="tsMinimizeToTray" Grid.Column="1" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Excluded packages -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16,12">
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="txtExcludedTitle" Text="Paquetes excluidos"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock x:Name="txtExcludedSubtitle" Text="Estos paquetes no se incluirán en las actualizaciones."
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <ListView x:Name="lstExcluidos"
                                  MaxHeight="200"
                                  SelectionMode="Single" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="btnQuitar" Content="Quitar seleccionado"
                                    Click="BtnQuitar_Click" MinWidth="160" />
                            <Button x:Name="btnLimpiar" Content="Limpiar lista"
                                    Click="BtnLimpiar_Click" MinWidth="120" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="20,0,20,20">
            <Button x:Name="btnGuardar"
                    Style="{StaticResource AccentButtonStyle}"
                    Content="Guardar"
                    Click="BtnGuardar_Click"
                    MinWidth="120" Height="36" />
            <Button x:Name="btnCancelar"
                    Content="Cancelar"
                    Click="BtnCancelar_Click"
                    MinWidth="120" Height="36" />
        </StackPanel>
    </Grid>
</Window>
