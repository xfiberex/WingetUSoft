<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="WingetUSoft.AboutDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    CornerRadius="8">

    <ContentDialog.PrimaryButtonStyle>
        <Style TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
            <Setter Property="CornerRadius" Value="4" />
        </Style>
    </ContentDialog.PrimaryButtonStyle>
    <ContentDialog.CloseButtonStyle>
        <Style TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="CornerRadius" Value="4" />
        </Style>
    </ContentDialog.CloseButtonStyle>

    <ScrollViewer MaxHeight="420" VerticalScrollBarVisibility="Auto"
                  HorizontalScrollMode="Disabled" HorizontalScrollBarVisibility="Disabled">
        <StackPanel MaxWidth="400" Spacing="8">
            <TextBlock Text="WingetUSoft" FontWeight="SemiBold" FontSize="18"
                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
            <TextBlock x:Name="VersionText" Opacity="0.7" FontSize="12" />
            <TextBlock x:Name="DescText" TextWrapping="Wrap" FontSize="13" />
            <TextBlock x:Name="CopyrightText" TextWrapping="Wrap" FontSize="12" Opacity="0.85" />

            <Border Height="1" Margin="0,4"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <TextBlock x:Name="PrivacyHeader" FontWeight="SemiBold" FontSize="13" />
            <TextBlock x:Name="PrivacyText" TextWrapping="Wrap" FontSize="12" Opacity="0.9" />
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
