<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WingetUSoft.SearchWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WingetUSoft"
    Title="WingetUSoft - Buscar e instalar">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.Resources>
            <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="32" Background="Transparent">
            <TextBlock x:Name="txtTitleBar" Text="Buscar e instalar"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"
                       Style="{StaticResource CaptionTextBlockStyle}" />
        </Grid>

        <Grid Grid.Row="1" Padding="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header Card -->
            <Border Grid.Row="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20,14"
                    Margin="0,0,0,12">
                <StackPanel Spacing="4">
                    <TextBlock x:Name="txtHeaderTitle" Text="Buscar e instalar programas"
                               Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock x:Name="txtSubtitulo"
                               Text="Busca en el catálogo de winget e instala lo que necesites."
                               Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Search + Actions Card -->
            <Border Grid.Row="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16,12"
                    Margin="0,0,0,12">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBox x:Name="txtBuscar"
                                 PlaceholderText="Nombre, Id o palabra clave..."
                                 Width="320" Height="36"
                                 VerticalAlignment="Center"
                                 KeyDown="TxtBuscar_KeyDown"
                                 AutomationProperties.Name="Buscar en el catálogo de winget" />
                        <Button x:Name="btnBuscar" Style="{StaticResource AccentButtonStyle}"
                                Content="Buscar"
                                Click="BtnBuscar_Click"
                                MinWidth="120" Height="36" />
                        <Button x:Name="btnInstalar"
                                Content="Instalar seleccionado"
                                Click="BtnInstalar_Click"
                                IsEnabled="False"
                                MinWidth="180" Height="36" />
                        <Button x:Name="btnCancelar"
                                Content="Cancelar"
                                Click="BtnCancelar_Click"
                                IsEnabled="False"
                                MinWidth="100" Height="36" />
                    </StackPanel>
                    <TextBlock x:Name="txtContador"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>

            <!-- Results + Log -->
            <Grid Grid.Row="2" Margin="0,0,0,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" MinHeight="100" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="txtListHeader" Grid.Row="0"
                                   Text="Resultados"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   Margin="4,0,0,8" />

                        <Grid Grid.Row="1" Height="36"
                              Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                              CornerRadius="4,4,0,0"
                              Padding="8,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="colNombre" Grid.Column="0" Text="Nombre" VerticalAlignment="Center" FontWeight="SemiBold" Margin="4,0,0,0"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock x:Name="colId" Grid.Column="1" Text="Id" VerticalAlignment="Center" FontWeight="SemiBold" Margin="8,0,0,0"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock x:Name="colVersion" Grid.Column="2" Text="Versión" VerticalAlignment="Center" FontWeight="SemiBold" Margin="8,0,0,0"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock x:Name="colFuente" Grid.Column="3" Text="Fuente" VerticalAlignment="Center" FontWeight="SemiBold" Margin="8,0,0,0"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock x:Name="colEstado" Grid.Column="4" Text="Estado" VerticalAlignment="Center" FontWeight="SemiBold" Margin="8,0,0,0"
                                       TextTrimming="CharacterEllipsis" />
                        </Grid>

                        <ListView x:Name="lvResults"
                                  Grid.Row="2"
                                  SelectionMode="Single"
                                  SelectionChanged="LvResults_SelectionChanged">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="36" Padding="8,0"
                                          AutomationProperties.Name="{Binding RowLabel}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="90" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" Margin="4,0,0,0" />
                                        <TextBlock Grid.Column="1" Text="{Binding Id}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" Margin="8,0,0,0" />
                                        <TextBlock Grid.Column="2" Text="{Binding Version}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" Margin="8,0,0,0" />
                                        <TextBlock Grid.Column="3" Text="{Binding Source}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" Margin="8,0,0,0"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <!-- "Ya instalado" evita el error más tonto: intentar instalar algo que ya está.
                                             Se marca en la fila, no se oculta: el usuario buscó eso y debe encontrarlo. -->
                                        <TextBlock Grid.Column="4" Text="{Binding InstalledLabel}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" Margin="8,0,0,0"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Height="6" Background="Transparent" />

                <Border Grid.Row="2"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="txtLogHeader" Grid.Row="0"
                                   Text="Actividad"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   Margin="4,0,0,8" />
                        <ScrollViewer Grid.Row="1"
                                      x:Name="scrollLog"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                            <RichTextBlock x:Name="rtbLog"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           IsTextSelectionEnabled="True"
                                           TextWrapping="NoWrap" />
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- Status Bar -->
            <Border Grid.Row="3"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="txtEstado"
                               Grid.Column="0"
                               Text="Listo."
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />
                    <ProgressRing x:Name="progressRing"
                                  Grid.Column="1"
                                  IsActive="False"
                                  Width="20" Height="20"
                                  Margin="12,0,0,0" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
